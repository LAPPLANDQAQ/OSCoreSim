# ============================================
# C++ / CMake / MSVC Project — Git Ignore
# ============================================

# --- Build outputs ---
# build/ 中只提交脱敏构建摘要，缓存、工程文件和二进制产物仍保持忽略。
build/*
!build/BUILD_INFO.md
out/
obj/
[Bb]in/
[Dd]ebug/
[Rr]elease/
x64/
x86/
*.exe
*.dll
*.so
*.dylib
*.lib
*.a
*.pdb
*.ilk
*.exp
*.obj
*.o
*.lo
*.la
*.lai

# --- Visual Studio ---
.vs/
*.user
*.suo
*.sln.docstates
*.vcxproj.user
*.vcxproj.filters
*.vc.db
*.cachefile
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf

# --- CMake ---
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CMakeConfigureLog.yaml
CTestTestfile.cmake
DartConfiguration.tcl
*.cmake
!CMakeLists.txt

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~
*.DS_Store
Thumbs.db

# --- Package managers ---
vcpkg_installed/
conan/
_packages/

# --- Test outputs ---
Testing/
*.testlog
*.trx

# --- Temp / OS ---
*.tmp
*.temp
*.log
*.bak

# --- Runtime data directory ---
# data/ 是运行时目录，二进制快照由程序在运行时生成。
# 源码仓库只保留 data/.gitkeep 占位目录，不提交 *.bin 快照文件。
data/*.bin
data/*.tmp
!data/.gitkeep
